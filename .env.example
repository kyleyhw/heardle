# Heardle configuration — all fields are OPTIONAL. A bare clone with no
# .env at all boots in iTunes mode with ephemeral session secrets, which is
# fine for personal local use. Override the fields below for production or
# for the (currently unwired) Spotify backend.

# --- Audio backend ---------------------------------------------------------
# "itunes"  (default) — zero-setup: uses the iTunes Search API for metadata
#                        and 30-second preview MP3s. Recommended.
# "spotify" (future) — reserved for a later re-enablement; currently causes
#                        /game/new to return 503.
AUDIO_BACKEND=itunes

# iTunes storefront — two-letter ISO country. US works for English-language
# catalogue and is the default.
ITUNES_COUNTRY=US

# --- Session signing -------------------------------------------------------
# HMAC secret for signing session cookies (Starlette SessionMiddleware).
# Leave blank to let the server generate an ephemeral random token per
# process start — sessions will reset on every restart.
# For deployment, generate a stable value:
#     python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=
GAME_STATE_SECRET=

# --- Spotify (only needed when AUDIO_BACKEND=spotify) ---------------------
# Register at https://developer.spotify.com/dashboard and set the redirect
# URI in the Dashboard to match SPOTIFY_REDIRECT_URI below. Not used in
# iTunes mode.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# --- Corpus (optional — only used if you build the parquet) ---------------
# Offline snapshot for autocomplete; currently unused in iTunes mode but
# kept for a future richer-autocomplete toggle. See docs/corpus_threshold.md.
POPULAR_CORPUS_PATH=data/popular_corpus.parquet
POPULARITY_THRESHOLD=25
YEAR_THRESHOLD=2000

# Spotify OAuth credentials — register an app at https://developer.spotify.com/dashboard
# and copy the client id / client secret here.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must exactly match the redirect URI registered in the Spotify dashboard.
# For local development keep the default; for deployment update both here and in the dashboard.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# HMAC secret for signing session cookies (Starlette SessionMiddleware).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=replace_with_64_byte_urlsafe_token

# HMAC secret for signing game state sent to the client (target track id hidden from browser).
# Generate the same way as SESSION_SECRET — keep distinct.
GAME_STATE_SECRET=replace_with_64_byte_urlsafe_token

# Path to the popular-songs corpus parquet (loaded at server startup).
POPULAR_CORPUS_PATH=data/popular_corpus.parquet

# Popularity threshold τ applied to the corpus snapshot. Ignored when the snapshot
# lacks a popularity column (e.g. the 1.2M rodolfofigueroa dataset). Rationale in
# docs/corpus_threshold.md.
POPULARITY_THRESHOLD=25

# Release-year cutoff applied as a secondary popularity proxy when the dataset
# does not expose popularity directly. Tracks older than this are dropped from
# the autocomplete pool. 2000 trims the long pre-Spotify-era catalogue tail
# while keeping ~60% of a 1.2M modern-catalogue snapshot.
YEAR_THRESHOLD=2000

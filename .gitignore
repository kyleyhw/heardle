# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
venv/

# Secrets and local config
.env
.env.*
!.env.example

# OS cruft
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Tooling caches
.pytest_cache/
.ruff_cache/
.ty_cache/
.mypy_cache/
.cache/

# Generated data (large parquet snapshots, downloaded datasets)
data/*.parquet
data/raw/

# Test report artefacts other than markdown reports
tests/reports/*.png
tests/reports/*.html

# Documentation-generated plots (keep the .md, drop regenerable images)
docs/_build/

# Playwright diagnostic output (screenshots + logs)
diagnose/
